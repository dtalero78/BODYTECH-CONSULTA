# Server Configuration
PORT=3000
NODE_ENV=development

# Twilio Video Credentials (for video calls)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio API Key (required for Twilio Video)
TWILIO_API_KEY_SID=your_api_key_sid_here
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# Twilio Voice Credentials (for phone calls)
TWILIO_VOICE_ACCOUNT_SID=your_voice_account_sid_here
TWILIO_VOICE_AUTH_TOKEN=your_voice_auth_token_here

# WhatsApp API (WHAPI) - Required for session reports
WHAPI_TOKEN=your_whapi_token_here

# JWT Secret for application authentication
JWT_SECRET=your_jwt_secret_here

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL Database (Digital Ocean) - Para backup y consultas rápidas
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_HOST=your_postgres_host_here
POSTGRES_PORT=25060
POSTGRES_DATABASE=defaultdb

# Integración Trepsi (B2B). API Key que Trepsi envía como
# `Authorization: Bearer <TREPSI_API_KEY>` cuando llama a
# /api/v1/integrations/trepsi/*. Generar 32+ bytes aleatorios:
#   openssl rand -hex 32
# Sin esta variable, los endpoints responden 503.
TREPSI_API_KEY=

# Resend (reset de contraseña por email)
RESEND_API_KEY=re_...
RESEND_FROM=Bodytech <no-reply@tudominio.com>
